# ==========================================
# BACKEND (Python)
# ==========================================
# Virtual environments anywhere in the project
**/venv/
**/.venv/
**/env/
**/ENV/

# Python cache files
**/__pycache__/
*.py[cod]

# ==========================================
# FRONTEND (JavaScript / Node)
# ==========================================
# Heavy frontend download folders
**/node_modules/
**/.pnpm-store/

# Frontend build outputs
**/dist/
**/build/
**/.next/
**/.nuxt/

# Frontend logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==========================================
# SECRETS & ENVIRONMENT VARIABLES (CRITICAL)
# ==========================================
# This blocks any .env file anywhere in your project
**/.env
**/.env.local
**/.env.*.local

# ==========================================
# SYSTEM & EDITORS
# ==========================================
.DS_Store
Thumbs.db
.vscode/
.idea/